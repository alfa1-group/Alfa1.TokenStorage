<Project>
  <PropertyGroup>
    <Version>0.0.1-preview-04</Version>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <LangVersion>13</LangVersion>
    <Authors>Stef Heyenrath</Authors>
    <Owners>Stef Heyenrath</Owners>
    <Copyright>Copyright © Stef Heyenrath</Copyright>
    <!--<PackageReleaseNotes>See ReleaseNotes.md</PackageReleaseNotes>-->
    <PackageIcon>logo-128x128.png</PackageIcon>
    <ApplicationIcon>../../resources/logo.ico</ApplicationIcon>
    <PackageProjectUrl>https://github.com/alfa1-group/Alfa1.TokenStorage</PackageProjectUrl>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <RepositoryType>git</RepositoryType>
    <RepositoryUrl>https://github.com/alfa1-group/Alfa1.TokenStorage</RepositoryUrl>
  </PropertyGroup>

  <PropertyGroup Condition="'$(Configuration)' == 'Release'">
    <GeneratePackageOnBuild>true</GeneratePackageOnBuild>
  </PropertyGroup>

  <ItemGroup>
    <None Include="../../resources/logo-128x128.png" Pack="true" PackagePath="" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.SourceLink.GitHub" Version="10.0.203">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
  </ItemGroup>

</Project>